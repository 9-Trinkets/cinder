        "usage": "continue",
        "example": "continue",
        "advances_time": true
      },
      "content_event": {
        "id": "isla.reading_progressed",
        "event_text": "Noa keeps reading while the cafe settles into a quieter rhythm.",
        "hook_id": "isla.reading_progress",
        "signals": ["reading_step"]
      }
    },
    {
      "id": "finish_reading",
      "group": "book",
      "command": "FINISH READING",
      "target_mode": "none",
      "player_enabled": true,
      "player_phrases": ["finish", "finish reading", "close book", "done reading"],

      "player_enabled": true,
      "player_phrases": ["listen", "hear"],
      "player_command": {
        "target_mode": "first_actor_in_room",
        "usage": "listen",
        "example": "listen",
        "advances_time": false
      }
    },
    {
      "id": "recommend_book",
      "group": "book",
      "command": "RECOMMEND BOOK",
      "target_mode": "none",
      "player_enabled": true,
      "player_phrases": ["recommend", "recommend book", "book recommendation", "choose a book", "pick a book"],
      "player_command": {
        "usage": "recommend",
        "example": "recommend",
        "advances_time": false
      },
      "content_event": {
        "id": "isla.recommendation_started",
        "event_text": "You rest a hand on the shelf and let Noa know you're ready to choose a book together.",
        "signals": ["recommendation_started"],
        "open_menu": "book-recommendation"
      }
    },
    {

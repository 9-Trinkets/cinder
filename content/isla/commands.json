{
  "actions": [
    {
      "id": "look",
      "group": "observation",
      "command": "LOOK",
      "target_mode": "none",
      "effects": ["observe_room"],
      "player_enabled": true,
      "player_phrases": ["look", "l", "look at", "look room", "look around", "inspect room", "examine", "x"],
      "player_command": {
        "usage": "look [at <thing or person>]",
        "example": "look around",
        "advances_time": false,
        "input": { "required": false }
      }
    },
    {
      "id": "speak",
      "group": "conversation",
      "command": "SPEAK",
      "target_mode": "actor_optional",
      "outcome_mode": "dialogue",
      "player_enabled": true,
      "player_phrases": ["talk to", "talk", "speak to", "speak"],
      "player_command": {
        "target_mode": "actor_reference",
        "usage": "talk to <patient> [message]",
        "example": "talk to noa what feels hardest right now",
        "advances_time": false,
        "input": { "required": true }
      }
    },
    {
      "id": "listen",
      "group": "conversation",
      "command": "LISTEN",
      "target_mode": "none",

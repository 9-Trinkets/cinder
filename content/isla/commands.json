      "content_event": {
        "id": "isla.reading_complete",
        "event_text": "Noa closes the book and looks up, waiting for what the session means now.",
        "hook_id": "isla.reading_complete",
        "signals": ["reading_complete", "ending_check"]
      }
    },
    {
      "id": "inspect_feature",
      "group": "observation",
      "command": "INSPECT FEATURE",

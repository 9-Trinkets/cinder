  "actor.turn_action_guidance": {
    "rule": "effect_table",
    "rule_config": {
      "cases_path": "rules",
      "next_on_match": "complete",
      "next_on_default": "complete",
      "default_payload_template": {
        "effects": []
      }
    },
    "input_overlay": {
      "rules": [
        {
          "conditions": [
            {
              "path": "active_stage_ids",
              "operator": "array_contains",
              "value": "introduce-everyone-first-evening"
            }
          ],
          "payload_template": {
            "kind": "hide_affordance",
            "affordance_id": "move"
          }
        },
        {
          "conditions": [
            {
              "path": "actor_stats.stamina",
              "operator": "less_than",
              "value": 5
            },
            {
              "path": "affordances.rest.available",
              "operator": "equal",
              "value": true
            }
          ],
          "payload_template": {
            "kind": "prioritize_affordance",
            "affordance_id": "rest",
            "by": 20
          }
        },
        {
          "conditions": [
            {
              "path": "affordances.hug.available",
              "operator": "equal",
              "value": true
            },
            {
              "path": "top_speak_candidate.pair_stats.connection",
              "operator": "greater_than",
              "value": 4
            },
            {
              "path": "top_speak_candidate.pair_stats.safety",
              "operator": "greater_than",
              "value": 5
            },
            {
              "path": "top_speak_candidate.pair_stats.attraction",
              "operator": "greater_than",
              "value": 6
            },
            {
              "path": "actor_stats.stamina",
              "operator": "greater_than",
              "value": 4
            },
            {
              "path": "actor_stats.confidence",
              "operator": "greater_than",
              "value": 4
            },
            {
              "path": "actor_stats.hunger",
              "operator": "less_than",
              "value": 6
            }
          ],
          "payload_template": {
            "kind": "prioritize_affordance",
            "affordance_id": "hug",
            "by": 12
          }
        },
        {
          "conditions": [
            {
              "path": "affordances.hug.available",
              "operator": "equal",
              "value": true
            },
            {
              "path": "actor_stats.stamina",
              "operator": "less_than",
              "value": 5
            }
          ],
          "payload_template": {
            "kind": "prioritize_affordance",
            "affordance_id": "hug",
            "by": -15
          }
        },
        {
          "conditions": [
            {
              "path": "affordances.hug.available",
              "operator": "equal",
              "value": true
            },
            {
              "path": "actor_stats.confidence",
              "operator": "less_than",
              "value": 5
            }
          ],
          "payload_template": {
            "kind": "prioritize_affordance",
            "affordance_id": "hug",
            "by": -10
          }
        },
        {
          "conditions": [
            {
              "path": "affordances.hug.available",
              "operator": "equal",
              "value": true
            },
            {
              "path": "actor_stats.hunger",
              "operator": "greater_than",
              "value": 5
            }
          ],
          "payload_template": {
            "kind": "prioritize_affordance",
            "affordance_id": "hug",
            "by": -10
          }
        },
        {
          "conditions": [
            {
              "path": "affordances.inspect_actor.available",
              "operator": "equal",
              "value": true
            },
            {
              "path": "top_speak_candidate.pair_stats.connection",
              "operator": "less_than",
              "value": 4
            }
          ],
          "payload_template": {
            "kind": "prioritize_affordance",
            "affordance_id": "inspect_actor",
            "by": 10
          }
        },
        {
          "conditions": [
            {
              "path": "affordances.inspect_actor.available",
              "operator": "equal",
              "value": true
            },
            {
              "path": "top_speak_candidate.pair_stats.safety",
              "operator": "less_than",
              "value": 3
            }
          ],
          "payload_template": {
            "kind": "prioritize_affordance",
            "affordance_id": "inspect_actor",
            "by": 10
          }
        },
        {
          "conditions": [
            {
              "path": "affordances.inspect_feature.available",
              "operator": "equal",
              "value": true
            },
            {
              "path": "unseen_feature_count",
              "operator": "greater_than",
              "value": 0
            }
          ],
          "payload_template": {
            "kind": "prioritize_affordance",
            "affordance_id": "inspect_feature",
            "by": 8
          }
        }
      ]
    }

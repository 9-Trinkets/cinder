  "actor.consumed": {
    "rule": "effect_table",
    "rule_config": {
      "cases_path": "rules",
      "next_on_match": "complete",
      "next_on_default": "complete",
      "default_payload_template": {
        "effects": []
      }
    },
    "input_overlay": {
      "rules": [
        {
          "conditions": [
            { "path": "hunger_recovery", "operator": "greater_than", "value": 0 }
          ],
          "payload_template": {
            "kind": "adjust_actor_stat",
            "actor_id": "$input.actor_id",
            "stat": "hunger",
            "delta": "-${input.hunger_recovery}"
          }
        },
        {
          "conditions": [
            { "path": "stamina_recovery", "operator": "greater_than", "value": 0 }
          ],
          "payload_template": {
            "kind": "adjust_actor_stat",
            "actor_id": "$input.actor_id",
            "stat": "stamina",
            "delta": "$input.stamina_recovery"
          }
        }
      ]
    }
  },

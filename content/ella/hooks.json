{
  "actor.state_notes": {
    "rule": "effect_table",
    "rule_config": {
      "cases_path": "rules",
      "next_on_match": "complete",
      "next_on_default": "complete",
      "effects_field": "notes",
      "default_payload_template": {
        "notes": []
      }
    },
    "input_overlay": {
      "rules": [
        {
          "conditions": [
            { "path": "actor_stats.hunger", "operator": "greater_than_or_equal", "value": 7 }
          ],
          "payload_template": "You are genuinely hungry now, and food is getting harder to ignore."
        },
        {
          "conditions": [
            { "path": "actor_stats.hunger", "operator": "greater_than_or_equal", "value": 4 },
            { "path": "actor_stats.hunger", "operator": "less_than", "value": 7 }
          ],
          "payload_template": "You are starting to feel hungry."
        },
        {
          "conditions": [
            { "path": "actor_stats.stamina", "operator": "less_than_or_equal", "value": 2 }
          ],
          "payload_template": "Your stamina is running low, so you do not want to push yourself too hard."
        },
        {
          "conditions": [
            { "path": "actor_stats.stamina", "operator": "less_than_or_equal", "value": 4 },
            { "path": "actor_stats.stamina", "operator": "greater_than", "value": 2 }
          ],
          "payload_template": "Your energy is starting to dip."
        }
      ]
    }
  },
  "actor.time_advanced": {
    "rule": "effect_table",
    "rule_config": {
      "cases_path": "rules",
      "next_on_match": "complete",
      "next_on_default": "complete",
      "default_payload_template": {
        "effects": []
      }
    },
    "input_overlay": {
      "rules": [
        {
          "conditions": [
            { "path": "stat", "operator": "equal", "value": "hunger" }
          ],
          "payload_template": {
            "kind": "adjust_actor_stat",
            "actor_id": "$input.actor_id",
            "stat": "hunger",
            "delta": 1
          }
        },
        {
          "conditions": [
            { "path": "stat", "operator": "equal", "value": "stamina" }
          ],
          "payload_template": {
            "kind": "adjust_actor_stat",
            "actor_id": "$input.actor_id",
            "stat": "stamina",
            "delta": -1
          }
        }
      ]
    }
  },
